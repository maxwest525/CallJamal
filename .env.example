# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# SlickText SMS
SLICKTEXT_PUBLIC_KEY=your-slicktext-public-key
SLICKTEXT_PRIVATE_KEY=your-slicktext-private-key
SLICKTEXT_MAIN_NUMBER=your-shared-team-phone-number

# Google Workspace
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_WORKSPACE_DOMAIN=your-company.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account-key.json
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@your-company.com

# Webhook
WEBHOOK_SECRET=your-webhook-secret-for-slicktext-incoming-sms
