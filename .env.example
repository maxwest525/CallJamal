# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# SlickText SMS
SLICKTEXT_PUBLIC_KEY=your-slicktext-public-key
SLICKTEXT_PRIVATE_KEY=your-slicktext-private-key
SLICKTEXT_MAIN_NUMBER=your-shared-team-phone-number

# Google Workspace / Gmail OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_WORKSPACE_DOMAIN=your-company.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account-key.json
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@your-company.com

# Google Workspace SSO — set to "true" to require a valid Google ID token on all /api/ requests
GOOGLE_AUTH_REQUIRED=false

# AI Assistant — set AI_PROVIDER to "gemini" or "claude"
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_CLIENT_ID=your-slack-app-client-id
SLACK_CLIENT_SECRET=your-slack-app-client-secret

# Zapier / n8n Outbound Webhooks
# Leave blank to disable; multiple integrations can be set simultaneously
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-zap-id/
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/your-webhook-id

# Webhook
WEBHOOK_SECRET=your-webhook-secret-for-slicktext-incoming-sms

# Daily.co Video Huddles
# Sign up at https://daily.co to get an API key and your team domain
DAILY_CO_API_KEY=your-daily-co-api-key
DAILY_CO_DOMAIN=your-team.daily.co
